---
interface Props {
  photos: string[];
  imageBase: string;
  albumSlug: string;
}

const { photos, imageBase, albumSlug } = Astro.props;
---

<div class="photo-grid" data-album={albumSlug}>
  {photos.map((photo, i) => (
    <button class="photo-item" data-index={i} type="button" aria-label={`View photo ${i + 1}`}>
      <img
        src={`${imageBase}/${albumSlug}/${photo}`}
        alt={`Wildlife photo ${i + 1}`}
        loading={i < 6 ? 'eager' : 'lazy'}
        decoding="async"
      />
    </button>
  ))}
</div>

<style>
  .photo-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
  }

  @media (min-width: 520px) {
    .photo-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 1000px) {
    .photo-grid { grid-template-columns: repeat(3, 1fr); }
  }

  .photo-item {
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    overflow: hidden;
    border-radius: var(--radius);
    line-height: 0;
  }

  .photo-item img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .photo-item:hover img {
    transform: scale(1.03);
  }
</style>
