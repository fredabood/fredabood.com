---
import BaseLayout from '../layouts/BaseLayout.astro';
import SocialLinks from '../components/SocialLinks.astro';
---

<BaseLayout title="Fred Abood" description="Data nerd from Michigan with a love for food, art, travel, and family.">
  <div class="landing">
    <h1>Fred Abood</h1>
    <p class="bio">
      Data nerd from Michigan with a love for food, art, travel, and family.
      I'm a life long learner, amateur caterer and wildlife photographer.
    </p>
    <nav class="landing-nav">
      <a href="https://notes.fredabood.com" class="landing-link">Fred's Notes</a>
      <span class="sep">/</span>
      <a href="/photos" class="landing-link">Photography</a>
    </nav>
    <div class="social-row">
      <SocialLinks />
    </div>
  </div>
</BaseLayout>

<style>
  .landing {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 6rem 0 4rem;
    min-height: 60vh;
    justify-content: center;
  }

  h1 {
    margin-bottom: 1rem;
  }

  .bio {
    max-width: 480px;
    color: var(--text);
    font-size: 1.1rem;
  }

  .landing-nav {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 2rem;
  }

  .landing-link {
    font-size: 1rem;
    font-weight: 500;
  }

  .sep {
    color: var(--bg-secondary);
  }

  .social-row {
    margin-top: 0.5rem;
  }
</style>
