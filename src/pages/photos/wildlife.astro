---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PhotoGrid from '../../components/PhotoGrid.astro';
import Lightbox from '../../components/Lightbox.astro';
import albums from '../../data/albums.json';

const album = albums.wildlife;
const imageBase = import.meta.env.PUBLIC_IMAGE_BASE || '/images';
---

<BaseLayout title={`${album.title} — Fred Abood`} description={`${album.title} photography by Fred Abood (${album.year}).`}>
  <div class="album-header">
    <a href="/photos" class="back-link">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
      Photography
    </a>
    <h1>{album.title}</h1>
    <span class="album-meta">{album.year} &middot; {album.photos.length} photos</span>
  </div>

  <PhotoGrid photos={album.photos} imageBase={imageBase} albumSlug="wildlife" />
  <Lightbox photos={album.photos} imageBase={imageBase} albumSlug="wildlife" />
</BaseLayout>

<style>
  .album-header {
    margin-bottom: 2rem;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.9rem;
    color: var(--text-secondary);
    margin-bottom: 0.75rem;
  }
  .back-link:hover {
    color: var(--link);
    opacity: 1;
  }

  h1 {
    margin-bottom: 0.25rem;
  }

  .album-meta {
    color: var(--text-secondary);
    font-size: 0.95rem;
  }
</style>
